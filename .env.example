# Template of environment variables used by the Muralist backend stack.
# Copy to `.env` (gitignored) and fill in with real values. Never commit `.env`.

# DigitalOcean API token — used by doctl for provisioning App Platform + Managed
# MongoDB. Obtain from https://cloud.digitalocean.com/account/api/tokens.
DIGITALOCEAN_ACCESS_TOKEN=

# MongoDB connection URI — provided by DO Managed MongoDB after provisioning.
# For local development, run a local MongoDB or use mongodb-memory-server in tests.
MONGO_URI=

# MongoDB database name — the logical database inside the cluster that stores
# users, projects, sessions, etc. Defaults to "muralist" in staging/prod.
MONGO_DB_NAME=muralist

# Better Auth signing secret. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
BETTER_AUTH_SECRET=

# Public base URL of the web app (used for OAuth redirect_uri + CORS origin).
APP_BASE_URL=http://localhost:3000

# OAuth provider credentials. Obtain from each provider's developer console.
# All four providers should be configured before shipping; missing ones mean
# that provider's sign-in button is unavailable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

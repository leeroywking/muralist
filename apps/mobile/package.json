{
  "name": "@muralist/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "./index.ts",
  "scripts": {
    "dev": "expo start",
    "build": "expo export --platform ios --platform android",
    "prebuild:android": "CI=1 expo prebuild --platform android --no-install --clean",
    "prebuild:ios": "CI=1 expo prebuild --platform ios --no-install --clean",
    "test": "node ./scripts/validate-mobile-config.mjs",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "^52.0.18",
    "expo-status-bar": "^2.0.1",
    "react": "^18.3.1",
    "react-native": "^0.76.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "typescript": "^5.7.2"
  }
}
